# ============================================
# kweaver-ui-test 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# 目标系统 URL
BASE_URL=http://localhost:3000

# 测试用户凭据
TEST_USER=testuser
TEST_PASSWORD=testpass123

# 环境标识: dev | staging | production
TEST_ENV=dev

# ============================================
# agent-browser 配置
# ============================================

# Session 持久化（自动保存/恢复登录态）
# 格式建议：kweaver-{TEST_ENV}
AGENT_BROWSER_SESSION_NAME=kweaver-dev

# Session 加密密钥（可选，AES-256-GCM）
# 生成命令：openssl rand -hex 32
# AGENT_BROWSER_ENCRYPTION_KEY=

# Session 有效期（天），默认 7 天
# AGENT_BROWSER_STATE_EXPIRE_DAYS=7

# 截图存储目录
AGENT_BROWSER_SCREENSHOT_DIR=./screenshots

# 是否显示浏览器窗口（true=有头模式，调试时使用）
AGENT_BROWSER_HEADED=false

# ============================================
# 超时配置（毫秒）
# ============================================
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000
